{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SMRmanager",
  "version": "0.1.0",
  "identifier": "com.smr.smrmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SMRmanager",
        "width": 1280,
        "height": 900,
        "minWidth": 860,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
